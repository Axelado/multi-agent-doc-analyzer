# ===========================================
# Configuration — Plateforme Multi-Agent NLP
# ===========================================

# --- PostgreSQL ---
POSTGRES_USER=nlp_user
POSTGRES_PASSWORD=nlp_secret_password
POSTGRES_DB=nlp_platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_NUM_CTX=6144
OLLAMA_NUM_PREDICT=3072

# --- Modèles HuggingFace (locaux) ---
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-base
NLI_MODEL=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
EMBEDDING_DEVICE=cpu
RERANKER_DEVICE=cpu
NLI_DEVICE=cpu

# --- Fiabilité pipeline ---
STEP_TIMEOUT_PARSE_SEC=120
STEP_TIMEOUT_INDEX_SEC=240
STEP_TIMEOUT_ANALYZE_SEC=300
STEP_TIMEOUT_VERIFY_SEC=300
STEP_TIMEOUT_EDIT_SEC=180

STEP_RETRY_PARSE=2
STEP_RETRY_INDEX=2
STEP_RETRY_ANALYZE=2
STEP_RETRY_VERIFY=2
STEP_RETRY_EDIT=2

STEP_BACKOFF_BASE_SEC=5
STEP_BACKOFF_MAX_SEC=60

# --- Chemins ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# --- Qualité du résumé ---
ANALYST_CONTEXT_MAX_CHARS=14000
ANALYST_SUMMARY_TARGET_WORDS=300
ANALYST_SUMMARY_MIN_WORDS=180
ANALYST_SUMMARY_RETRY_COUNT=1
ANALYST_SECTION_SUMMARY_MAX=12

# --- Langfuse (optionnel) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- Application ---
APP_HOST=0.0.0.0
APP_PORT=8000
DASHBOARD_PORT=8501
LOG_LEVEL=INFO
